# Backend profile
SPRING_PROFILES_ACTIVE=prod

# Database (RDS)
DB_URL=jdbc:postgresql://<RDS_ENDPOINT>:5432/quinta_dalam_db
DB_USERNAME=<RDS_USER>
DB_PASSWORD=<RDS_PASSWORD>

# Security
JWT_SECRET=<STRONG_SECRET_MIN_32_CHARS>
JWT_REQUIRE_STRONG_SECRET=true
APP_CORS_ALLOWED_ORIGINS=https://<FRONTEND_DOMAIN>
APP_FRONTEND_BASE_URL=https://<FRONTEND_DOMAIN>
APP_ICAL_EXPORT_TOKEN=<STRONG_ICAL_TOKEN>

# Stripe
PAYMENT_STRIPE_MODE=live
PAYMENT_STRIPE_SECRET_KEY=<STRIPE_SECRET_KEY>
PAYMENT_WEBHOOK_SECRET=<STRIPE_WEBHOOK_SECRET>
VITE_STRIPE_PUBLISHABLE_KEY=<STRIPE_PUBLISHABLE_KEY>

# Mail
MAIL_HOST=<SMTP_HOST>
MAIL_PORT=587
MAIL_USERNAME=<SMTP_USER>
MAIL_PASSWORD=<SMTP_PASSWORD>
MAIL_FROM=no-reply@quintadalam.com

# Frontend
VITE_API_BASE_URL=https://<BACKEND_DOMAIN>
VITE_API_TIMEOUT_MS=20000

# Logs
APP_LOG_FILE=/var/log/quintadalam/backend-prod.log
