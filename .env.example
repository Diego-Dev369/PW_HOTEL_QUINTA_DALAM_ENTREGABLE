# ==============================================
# Hotel Quinta Dalam - Environment Example
# Copy to `.env` in repo root and fill values.
# ==============================================

# ---------- Runtime profile ----------
SPRING_PROFILES_ACTIVE=dev

# ---------- PostgreSQL ----------
DB_URL=jdbc:postgresql://localhost:5432/quintadalam
DB_USERNAME=postgres
DB_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---------- Security ----------
JWT_SECRET=replace_with_minimum_32_characters_secure_secret
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- Stripe ----------
PAYMENT_STRIPE_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# ---------- Mail relay ----------
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@quintadalam.com

# ---------- Frontend ----------
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ---------- Optional production hardening ----------
# JWT_REQUIRE_STRONG_SECRET=true
# APP_CORS_ALLOWED_ORIGINS=https://tu-dominio.com
# SERVER_SSL_ENABLED=true
