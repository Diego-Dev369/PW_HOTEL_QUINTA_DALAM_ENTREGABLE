# -----------------------------
# Runtime and local tools
# -----------------------------
.runtime/
.aider*

# -----------------------------
# Environment and secrets
# -----------------------------
.env
.env.*
!.env.example
!config/env/.env.*.example
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*
*.pem
*.key
*.p12
*.jks

# -----------------------------
# Dependency and build outputs
# -----------------------------
frontend/node_modules/
frontend/dist/
backend/target/
backend/.m2/
backend/.mvn/wrapper/dists/
*.jar
*.war
*.ear

# -----------------------------
# Logs and temporary files
# -----------------------------
*.log
logs/
ops/logs/*
!ops/logs/.gitkeep
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
tmp/
temp/
*.tmp

# -----------------------------
# Backups and dumps
# -----------------------------
ops/backups/*
!ops/backups/.gitkeep
*.sql.gz
*.dump
*.bak

# -----------------------------
# Coverage, reports, scans
# -----------------------------
coverage/
.nyc_output/
reports/
*.lcov
dependency-check-report.*

# -----------------------------
# IDE / OS noise
# -----------------------------
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
